{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Backup & Disaster Recovery monitoring dashboard",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Backup Status Overview",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "postgres_backup_status{job=\"postgres_backup\"}",
          "legendFormat": "PostgreSQL - {{host}}",
          "refId": "A"
        },
        {
          "expr": "redis_backup_status{job=\"redis_backup\"}",
          "legendFormat": "Redis - {{host}}",
          "refId": "B"
        },
        {
          "expr": "backup_verification_status{job=\"backup_verification\"}",
          "legendFormat": "Verification - {{test}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "FAILED", "color": "red" } }, "type": "value" },
            { "options": { "1": { "text": "OK", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Last PostgreSQL Backup",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "(time() - postgres_backup_last_success_timestamp{job=\"postgres_backup\"}) / 3600",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 12 },
              { "color": "orange", "value": 18 },
              { "color": "red", "value": 24 }
            ]
          }
        }
      }
    },
    {
      "title": "Last Redis Backup",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 4 },
      "targets": [
        {
          "expr": "(time() - redis_backup_last_success_timestamp{job=\"redis_backup\"}) / 3600",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 12 },
              { "color": "orange", "value": 18 },
              { "color": "red", "value": 24 }
            ]
          }
        }
      }
    },
    {
      "title": "Last Verification",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "(time() - backup_verification_last_timestamp{job=\"backup_verification\"}) / 3600",
          "legendFormat": "{{test}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "orange", "value": 48 },
              { "color": "red", "value": 72 }
            ]
          }
        }
      }
    },
    {
      "title": "Velero Last Backup",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 4 },
      "targets": [
        {
          "expr": "(time() - velero_backup_last_successful_timestamp) / 3600",
          "legendFormat": "Velero",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 12 },
              { "color": "orange", "value": 18 },
              { "color": "red", "value": 24 }
            ]
          }
        }
      }
    },
    {
      "title": "PostgreSQL Backup Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "postgres_backup_duration_seconds{job=\"postgres_backup\"}",
          "legendFormat": "{{host}} - {{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "title": "PostgreSQL Backup Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "expr": "postgres_backup_size_bytes{job=\"postgres_backup\"}",
          "legendFormat": "{{host}} - {{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "title": "Redis Backup Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "redis_backup_duration_seconds{job=\"redis_backup\"}",
          "legendFormat": "{{host}} - {{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "title": "Redis Backup Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "targets": [
        {
          "expr": "redis_backup_size_bytes{job=\"redis_backup\"}",
          "legendFormat": "{{host}} - {{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "title": "RPO Compliance (Recovery Point Objective < 15min)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "(time() - postgres_backup_last_success_timestamp{job=\"postgres_backup\"}) / 60",
          "legendFormat": "PostgreSQL RPO",
          "refId": "A"
        },
        {
          "expr": "(time() - redis_backup_last_success_timestamp{job=\"redis_backup\"}) / 60",
          "legendFormat": "Redis RPO",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "min": 0,
          "max": 60,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "title": "Backup Success Rate (24h)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "targets": [
        {
          "expr": "backup:success_rate:24h",
          "legendFormat": "PostgreSQL Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    },
    {
      "title": "Velero Backup History",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 34 },
      "targets": [
        {
          "expr": "velero_backup_attempt_total",
          "legendFormat": "{{name}} - {{phase}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Time", "desc": true }]
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["backup", "disaster-recovery", "sre", "email-converter"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "Backup & Disaster Recovery",
  "uid": "backup-dr-overview",
  "version": 1
}
