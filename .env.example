# =============================================================================
# Application Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# Application
APP_NAME=Email Converter SaaS
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/email_converter

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-256-bit-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_REMEMBER_ME_DAYS=30
MAX_SESSIONS_PER_USER=10
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# Cookie Settings
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# Email
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1
FRONTEND_URL=http://localhost:3000

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@emailconverter.com
SMTP_TLS=true

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/microsoft/callback

# Rate Limiting
RATE_LIMIT_AUTH_ATTEMPTS=5
RATE_LIMIT_AUTH_WINDOW_SECONDS=300
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_ENDPOINT=30
DAILY_API_QUOTA=10000

# Storage Configuration
STORAGE_PROVIDER=minio
STORAGE_LOCAL_PATH=./uploads
STORAGE_BUCKET=email-converter-uploads
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# License
LICENSE_ENCRYPTION_KEY=license-encryption-key-change-in-production-32chars
LICENSE_TOKEN_EXPIRY_HOURS=24
LICENSE_OFFLINE_TOKEN_EXPIRY_HOURS=72

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=email-converter

# Monitoring
HEALTH_CHECK_INTERVAL_SECONDS=60
ALERT_EVALUATION_INTERVAL_SECONDS=300
METRICS_COLLECTION_INTERVAL_SECONDS=60

# Upload
MAX_UPLOAD_SIZE_MB=10240
CHUNK_SIZE_MB=8

# Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
PASSWORD_EXPIRY_DAYS=90
PASSWORD_HISTORY_SIZE=5
MFA_LOCKOUT_ATTEMPTS=5
MFA_LOCKOUT_MINUTES=15

# Search
ELASTICSEARCH_URL=http://elasticsearch:9200
OPENSEARCH_URL=http://opensearch:9200
SEARCH_INDEX_NAME=email_converter
SEARCH_CACHE_TTL=300
SEARCH_MAX_RESULTS=10000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
